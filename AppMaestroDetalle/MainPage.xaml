<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMaestroDetalle.MainPage">

    <ScrollView BackgroundColor="#F5F5F5">
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Título Principal -->
            <Label Text="📦 Gestión de Pedidos" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black" Margin="0,0,0,10" />

            <!-- Maestro: Info del Pedido -->
            <Frame BorderColor="Transparent" CornerRadius="15" Padding="15" HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="15">
                    <Entry x:Name="txtId" Placeholder="ID del Pedido (Auto para Crear, Digitar para Leer/Actualizar)" Keyboard="Numeric" />
                    <BoxView HeightRequest="1" Color="LightGray" />
                    <Entry x:Name="txtCliente" Placeholder="Nombre del Cliente" />
                    <BoxView HeightRequest="1" Color="LightGray" />
                    <Entry x:Name="txtEstado" Placeholder="Estado (ej. pendiente)" />
                    <BoxView HeightRequest="1" Color="LightGray" />
                </VerticalStackLayout>
            </Frame>

            <!-- Detalle: Líneas de Pedido -->
            <Frame BorderColor="Transparent" CornerRadius="15" Padding="15" HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Líneas de Pedido" FontAttributes="Bold" TextColor="#D32F2F" FontSize="14" />
                    
                    <Grid ColumnDefinitions="*, 80, 50" ColumnSpacing="10" VerticalOptions="Center">
                        <Picker x:Name="pickerProducto" Title="Seleccionar producto" Grid.Column="0">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Café ($1.0)</x:String>
                                    <x:String>Croissant ($1.8)</x:String>
                                    <x:String>Zumo de naranja ($2.0)</x:String>
                                    <x:String>Tostada ($1.5)</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                        <Entry x:Name="txtCantidad" Placeholder="Cant." Keyboard="Numeric" Grid.Column="1" />

                        <Button Text="+" Clicked="BtnAgregarLinea_Clicked" CornerRadius="25" BackgroundColor="#7E57C2" TextColor="White" Grid.Column="2" WidthRequest="40" HeightRequest="40" Padding="0"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="0,5" />

                    <!-- Lista en Memoria -->
                    <CollectionView x:Name="listaLineas" HeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, Auto" Padding="5,10">
                                    <Label Text="{Binding Descripcion}" VerticalOptions="Center" TextColor="Black" />
                                    <Button Text="X" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=QuitarLineaCommand}" CommandParameter="{Binding .}" Grid.Column="1" TextColor="Red" BackgroundColor="Transparent" FontAttributes="Bold" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                        <Button Text="LIMPIAR TODO" Clicked="BtnLimpiarLineas_Clicked" BackgroundColor="Transparent" TextColor="#D32F2F" FontSize="12" Grid.Column="0" />
                        <Button Text="QUITAR ÚLTIMO" Clicked="BtnQuitarUltimo_Clicked" BackgroundColor="Transparent" TextColor="#D32F2F" FontSize="12" Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Botones CRUD -->
            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="10" RowSpacing="10" Margin="0,10">
                <Button Text="Crear" Clicked="BtnCrear_Clicked" BackgroundColor="#7E57C2" TextColor="White" CornerRadius="25" Grid.Row="0" Grid.Column="0" />
                <Button Text="LEER" Clicked="BtnLeer_Clicked" BackgroundColor="#F0F0F0" TextColor="Black" CornerRadius="25" Grid.Row="0" Grid.Column="1" />
                
                <Button Text="Actualizar" Clicked="BtnActualizar_Clicked" BackgroundColor="#455A64" TextColor="White" CornerRadius="25" Grid.Row="1" Grid.Column="0" />
                <Button Text="Eliminar" Clicked="BtnEliminar_Clicked" BackgroundColor="#D32F2F" TextColor="White" CornerRadius="25" Grid.Row="1" Grid.Column="1" />
            </Grid>

            <!-- Resumen Inferior -->
            <Label x:Name="lblResumen" Text="Resumen del pedido aparecerá aquí..." BackgroundColor="#E0E0E0" Padding="10" TextColor="Gray" FontSize="12" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
